# 0xide example config
#
# Copy to ~/.config/0xide/0xide.conf and edit. Lines are `key = value`,
# `#` starts a comment. With no config file, 0xide uses these same defaults.
# A line it can't parse is warned about on stderr and skipped — never fatal.

# --- general ---------------------------------------------------------------

# Primary modifier, referenced as MOD / $mod in binds below. super | alt | ctrl.
# (OXIDE_MOD=alt in the environment overrides this — handy when running nested
# under another compositor that grabs Super-chords.)
modifier = super

# Pixels between/around tiled windows.
gap = 10

# Background color of empty space, as `r g b` floats in 0..1.
background = 0.0 0.6 0.6

# --- monitors ----------------------------------------------------------------
#
# monitor = NAME, XxY[, SCALE]
#   NAME   the connector name, as logged on startup ("output <name> online...")
#          e.g. eDP-1, HDMI-A-1, WL-1 (nested).
#   XxY    explicit layout position in pixels (scale-aware — matches where
#          the output visually starts). Negative values allowed, e.g. `0x-1080`
#          to place an output directly above one that's 1080px tall at 0,0.
#   SCALE  optional, defaults to 1.0.
# An output with no matching `monitor` line keeps the default auto-placement
# (lined up to the right of existing outputs, scale 1.0).
#
# monitor = HDMI-A-1, 0x-1080, 1.0

# --- floating ----------------------------------------------------------------
#
# float = APP_ID
# Windows whose app id matches (case-insensitive) always open floating,
# centered, above the tiled windows. Dialogs (file pickers etc.) and windows
# that declare a fixed size float automatically at their own natural size —
# no rule needed.
#
# float = pavucontrol

# Default size of floating windows, as percentages of the screen's usable
# area (the space bars don't reserve). Applies to `float =` rule windows and
# to the togglefloating bind; dialogs keep their natural size.
float_size = 60% x 60%

# --- keybindings -----------------------------------------------------------
#
# bind = MODS, KEY, ACTION[, ARG]
#   MODS   space/`+` separated: MOD (=primary), SUPER, ALT, SHIFT, CTRL
#   KEY    an xkb key name: Return, Q, 1, space, F1, ... (case-insensitive)
#   ACTION spawn <cmd> | close | quit | focusnext | focusprev
#          | movefocus <l|r|u|d> | movewindow <l|r|u|d> | fullscreen
#          | togglefloating | workspace <n> | movetoworkspace <n>  (n = 1..9)

bind = MOD, Return, spawn, kitty
bind = MOD, Q, close
bind = MOD SHIFT, Q, quit

# Directional focus / move, screen-relative (spatial neighbor, no wraparound).
bind = MOD, H, movefocus, l
bind = MOD, J, movefocus, d
bind = MOD, K, movefocus, u
bind = MOD, L, movefocus, r
bind = MOD SHIFT, H, movewindow, l
bind = MOD SHIFT, J, movewindow, d
bind = MOD SHIFT, K, movewindow, u
bind = MOD SHIFT, L, movewindow, r

# Toggle the focused window fullscreen (full output, over bars). Clients can
# also request it themselves (F11 in a browser, mpv --fs).
bind = MOD, F, fullscreen

# Toggle the focused window between tiled and floating. On a floating window,
# movewindow (MOD SHIFT + hjkl above) nudges it instead of swapping tiles.
bind = MOD, V, togglefloating

bind = MOD, 1, workspace, 1
bind = MOD, 2, workspace, 2
bind = MOD, 3, workspace, 3
bind = MOD, 4, workspace, 4
bind = MOD, 5, workspace, 5
bind = MOD, 6, workspace, 6
bind = MOD, 7, workspace, 7
bind = MOD, 8, workspace, 8
bind = MOD, 9, workspace, 9

bind = MOD SHIFT, 1, movetoworkspace, 1
bind = MOD SHIFT, 2, movetoworkspace, 2
bind = MOD SHIFT, 3, movetoworkspace, 3
bind = MOD SHIFT, 4, movetoworkspace, 4
bind = MOD SHIFT, 5, movetoworkspace, 5
bind = MOD SHIFT, 6, movetoworkspace, 6
bind = MOD SHIFT, 7, movetoworkspace, 7
bind = MOD SHIFT, 8, movetoworkspace, 8
bind = MOD SHIFT, 9, movetoworkspace, 9
