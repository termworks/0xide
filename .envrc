# Project env for 0xide. Build needs nothing special today — wlroots is
# found via pkg-config and the toolchain is pinned by rust-toolchain.toml.
# When we pin our own wlroots build, its PKG_CONFIG_PATH/LD_LIBRARY_PATH
# go here.

export RUST_BACKTRACE=1

# Per-scenario vars stay on the command line, NOT here (they change what a
# plain run does): WLR_BACKENDS=headless, WLR_WL_OUTPUTS=2, OXIDE_MOD=alt,
# OXIDE_CONFIG=..., WLR_DRM_DEVICES=/dev/dri/cardN.
